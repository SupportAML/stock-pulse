# =============================================================================
# StockPulse · Production Environment Variables
# =============================================================================
# Copy this file to .env.production.local for local testing of the prod build,
# or paste each value into Vercel Dashboard → Settings → Environment Variables.
#
# ⚠️  NEVER commit actual secrets. This file is a template — values are fake.
# =============================================================================


# -----------------------------------------------------------------------------
# NextAuth v5
# -----------------------------------------------------------------------------

# Full public URL of your app (no trailing slash)
# Vercel sets VERCEL_URL automatically, but NEXTAUTH_URL must be explicit.
NEXTAUTH_URL=https://stock-pulse.vercel.app

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_long_random_string


# -----------------------------------------------------------------------------
# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Authorized redirect URIs to add in Google Cloud Console:
#   https://stock-pulse.vercel.app/api/auth/callback/google
#   (also keep http://localhost:3000/api/auth/callback/google for dev)


# -----------------------------------------------------------------------------
# Alpaca Markets (https://alpaca.markets → Paper Trading → API Keys)
# -----------------------------------------------------------------------------

ALPACA_KEY=your-alpaca-api-key
ALPACA_SECRET=your-alpaca-api-secret

# Alpaca stream URL (paper trading)
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex


# -----------------------------------------------------------------------------
# Polygon.io (https://polygon.io → Dashboard → API Keys)
# -----------------------------------------------------------------------------

POLYGON_API_KEY=your-polygon-api-key


# -----------------------------------------------------------------------------
# Ollama AI (local inference)
# -----------------------------------------------------------------------------

# ⚠️  Vercel serverless functions CANNOT reach localhost.
# Options:
#   A) Leave blank → app falls back to algorithmic predictions (no AI needed)
#   B) Use a cloud Ollama instance (e.g. fly.io, Railway, or a VPS)
#      then set: OLLAMA_URL=https://your-ollama-server.fly.dev
#
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b


# -----------------------------------------------------------------------------
# WebSocket Gateway (stockpulse-gateway running on your VPS)
# -----------------------------------------------------------------------------

# Public WebSocket URL (wss://) after Nginx + TLS setup on your VPS
# Used by the Next.js client to connect to the live signal stream
NEXT_PUBLIC_GATEWAY_URL=wss://ws.yourdomain.com


# -----------------------------------------------------------------------------
# Firebase / Firestore (optional — for persistent watchlists / trade history)
# -----------------------------------------------------------------------------

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# Paste the private key with literal \n (Vercel handles multiline automatically)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
